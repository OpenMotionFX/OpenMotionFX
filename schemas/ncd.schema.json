{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenMotionFX/OpenMotionFX/blob/main/schemas/ncd.schema.json",
  "title": "OpenMotionFX Node Capability Descriptor",
  "description": "Spec reference: docs/SYSTEM-SPECIFICATION.md §11. One schema for every Node class, hardware or software, built from composable facets. An unrecognized facet MUST be ignored, not rejected, by any consumer of this document.",
  "type": "object",
  "required": ["ncd_version", "unit_uid", "product_name", "capabilities", "power", "connection", "auth"],
  "additionalProperties": true,
  "properties": {
    "ncd_version": {
      "type": "string",
      "const": "1.0"
    },
    "unit_uid": {
      "type": "string",
      "description": "ESP32 MAC-derived unique ID for hardware Nodes; any stable unique string for a Capture Node's software-only descriptor."
    },
    "product_name": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["facet"],
        "additionalProperties": true,
        "properties": {
          "facet": {
            "type": "string",
            "description": "Namespaced domain.subtype.variant, e.g. actuator.rotary.stepper, sensor.imu.6axis.",
            "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+(\\.[a-z0-9_]+)?$"
          },
          "params": {
            "type": "object",
            "description": "Facet-specific parameters, e.g. { \"driver\": \"TMC2209\", \"interface\": \"uart+step_dir\" }."
          }
        }
      }
    },
    "power": {
      "type": "object",
      "required": ["max_current_ma", "power_class"],
      "properties": {
        "max_current_ma": { "type": "integer", "minimum": 0 },
        "startup_inrush_ma": { "type": "integer", "minimum": 0 },
        "power_class": {
          "type": "string",
          "enum": ["A", "B", "C", "D"],
          "description": "Coarse ID_SENSE resistor-coded class (spec §9.2): A=500mA, B=1.5A, C=3.0A, D=6.0A."
        }
      }
    },
    "connection": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["wired_bib", "docked_wired", "undocked_wireless"]
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["tier"],
      "properties": {
        "tier": {
          "type": "integer",
          "enum": [0, 1],
          "description": "0 = Open/unsigned (spec §10), 1 = Certified against a factory-provisioned secure element."
        }
      }
    }
  }
}
